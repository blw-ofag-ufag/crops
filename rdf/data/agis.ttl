@prefix : <https://agriculture.ld.admin.ch/crops/> .
@prefix agis: <https://agriculture.ld.admin.ch/crops/agis/1.6/> .
@prefix cultivationtype: <https://agriculture.ld.admin.ch/crops/cultivationtype/> .

@prefix cube: <https://cube.link/> .
@prefix meta: <https://cube.link/meta/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix theme: <https://register.ld.admin.ch/opendataswiss/category/> .
@prefix blw: <https://register.ld.admin.ch/opendataswiss/org/bundesamt-fur-landwirtschaft-blw> .
@prefix frequency: <http://publications.europe.eu/resource/authority/frequency> .
@prefix status: <https://ld.admin.ch/vocabulary/CreativeWorkStatus/> .

# ==============================================================================
# DATASET METADATA
# ==============================================================================

agis: a void:Dataset,
        schema:Dataset,
        dcat:Dataset,
        cube:Cube ;
    dcterms:accrualPeriodicity frequency:ANNUAL ;
    dcterms:creator blw: ;
    schema:contributor blw: ;
    schema:creativeWorkStatus status:Draft ;
    schema:creator blw: ;
    schema:dateCreated "2026-03-02"^^xsd:date ;
    schema:datePublished "2026-03-02"^^xsd:date ;
    schema:description "Direktzahlungkulturen, ihre Codes und deren zeitliche Gültigkeit."@de,
        "Direct payment crops, their codes and their temporal validity."@en ;
    schema:name "Direktzahlungskulturen"@de,
        "Direct payment crops"@en ;
    schema:publisher blw: ;
    schema:version "1.6" ;
    schema:workExample <https://ld.admin.ch/application/visualize> ;
    dcat:contactPoint
        [
            a vcard:Organization ;
            vcard:fn "Bundesamt für Landwirtschaft"^^xsd:string ;
            vcard:hasEmail "info@blw.admin.ch"^^xsd:string
        ] ;
    dcat:theme theme:administration,
        theme:agriculture ;
    cube:observationConstraint agis:ObservationConstraint ;
    cube:observationSet agis:ObservationSet .

# ==============================================================================
# SHACL DATA MODEL
# ==============================================================================

agis:ObservationConstraint a sh:NodeShape ;
    sh:closed true ;
    sh:property
        [
            sh:order 2 ;
            schema:name "Kulturgruppe"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationGroup
        ],
        [
            sh:order 3 ;
            schema:name "Kultur"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType
        ],
        [
            sh:order 4 ;
            schema:name "Gültig von"@de ;
            schema:description "Ab welchem Jahr wurde diese Direktzahlungskultur offiziell verwendet?"@de ;
            sh:maxCount 1 ;
            sh:minInclusive "1999"^^xsd:gYear ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:gYear ;
            sh:path schema:validFrom ;
        ],
        [
            sh:order 5 ;
            schema:name "Gültig bis"@de ;
            schema:description "Bis in welchem Jahr wurde diese Direktzahlungskultur offiziell verwendet?"@de ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:gYear ;
            sh:path schema:validTo
        ],
        [
            a cube:KeyDimension ;
            schema:name "Identifikator"@de ;
            schema:description "Der LNF-Code, auch Kulturcode genannt, ist der allgemein gebräuchliche Identifikator für Direktzahlungskulturen in der Schweiz. Ein LNF-Code steht immer für dieselbe Kultur. Veraltete Codes werden nicht mehr gebraucht."@de ;
            sh:order 1 ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier
        ] .

# ==============================================================================
# OBSERVATION SET
# ==============================================================================

agis:ObservationSet a cube:ObservationSet ;
    cube:observation
        agis:501,
        agis:502,
        agis:503,
        agis:504,
        agis:505,
        agis:506,
        agis:507,
        agis:509,
        agis:702,
        agis:731 .

# ==============================================================================
# OBSERVATIONS
# ==============================================================================

agis:501 a cube:Observation ;
    schema:identifier "501"^^xsd:ID ;
    schema:validFrom "2021"^^xsd:gYear ;
    schema:validTo cube:Undefined ;
    :cultivationGroup cultivationtype:1 ;
    :cultivationType cultivationtype:501 .

agis:502 a cube:Observation ;
    schema:identifier "502"^^xsd:ID ;
    schema:validFrom "1999"^^xsd:gYear ;
    schema:validTo cube:Undefined ;
