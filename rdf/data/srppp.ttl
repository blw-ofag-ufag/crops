@prefix : <https://agriculture.ld.admin.ch/crops/> .
@prefix psm: <https://agriculture.ld.admin.ch/crops/psm/1/> .
@prefix cultivationtype: <https://agriculture.ld.admin.ch/crops/cultivationtype/> .

@prefix cube: <https://cube.link/> .
@prefix meta: <https://cube.link/meta/> .

@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix theme: <https://register.ld.admin.ch/opendataswiss/category/> .
@prefix blw: <https://register.ld.admin.ch/opendataswiss/org/bundesamt-fur-landwirtschaft-blw> .
@prefix frequency: <http://publications.europe.eu/resource/authority/frequency> .
@prefix status: <https://ld.admin.ch/vocabulary/CreativeWorkStatus/> .

# ==============================================================================
# DATASET METADATA
# ==============================================================================

psm: a void:Dataset,
        schema:Dataset,
        dcat:Dataset,
        cube:Cube ;
    dcterms:accrualPeriodicity frequency:ANNUAL ;
    dcterms:creator blw: ;
    schema:contributor blw: ;
    schema:creativeWorkStatus status:Draft ;
    schema:creator blw: ;
    schema:dateCreated "2026-03-09"^^xsd:date ;
    schema:datePublished "2026-03-09"^^xsd:date ;
    schema:description "Kulturen aus dem Pflanzenschutzmittelverzeichnis (PSM) und ihre Identifikatoren."@de,
        "Crops from the Plant Protection Products (PSM) registry and their identifiers."@en ;
    schema:name "PSM-Kulturen"@de,
        "PSM crops"@en ;
    schema:publisher blw: ;
    schema:version "1.0" ;
    schema:workExample <https://ld.admin.ch/application/visualize> ;
    dcat:contactPoint
        [
            a vcard:Organization ;
            vcard:fn "Bundesamt für Landwirtschaft"^^xsd:string ;
            vcard:hasEmail "info@blw.admin.ch"^^xsd:string
        ] ;
    dcat:theme theme:administration,
        theme:agriculture ;
    cube:observationConstraint psm:ObservationConstraint ;
    cube:observationSet psm:ObservationSet .

# ==============================================================================
# SHACL DATA MODEL
# ==============================================================================

psm:ObservationConstraint a sh:NodeShape ;
    sh:closed true ;
    sh:property
        [
            sh:order 2 ;
            schema:name "Kultur"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType
        ],
        [
            sh:order 1 ;
            a cube:KeyDimension ;
            schema:name "Identifikator"@de ;
            schema:description "Der offizielle Identifikator für Kulturen im schweizerischen Pflanzenschutzmittelverzeichnis."@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier ;
        ] .

# ==============================================================================
# OBSERVATION SET
# ==============================================================================

psm:ObservationSet a cube:ObservationSet ;
    cube:observation
        psm:1,
        psm:14,
        psm:19,
        psm:490,
        psm:491,
        psm:492,
        psm:493,
        psm:497,
        psm:498,
        psm:500,
        psm:501,
        psm:502,
        psm:504,
        psm:505,
        psm:510,
        psm:514,
        psm:520,
        psm:542,
        psm:549,
        psm:1000,
        psm:1006,
        psm:1011,
        psm:1012,
        psm:1017,
        psm:1021,
        psm:1027,
        psm:1032 .

