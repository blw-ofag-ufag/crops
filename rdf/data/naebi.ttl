@prefix : <https://agriculture.ld.admin.ch/crops/> .
@prefix naebi: <https://agriculture.ld.admin.ch/crops/naebi/1.11/> .
@prefix cultivationtype: <https://agriculture.ld.admin.ch/crops/cultivationtype/> .

@prefix cube: <https://cube.link/> .
@prefix meta: <https://cube.link/meta/> .

@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix theme: <https://register.ld.admin.ch/opendataswiss/category/> .
@prefix blw: <https://register.ld.admin.ch/opendataswiss/org/bundesamt-fur-landwirtschaft-blw> .
@prefix frequency: <http://publications.europe.eu/resource/authority/frequency> .
@prefix status: <https://ld.admin.ch/vocabulary/CreativeWorkStatus/> .

# ==============================================================================
# DATASET METADATA
# ==============================================================================

naebi: a void:Dataset,
        schema:Dataset,
        dcat:Dataset,
        cube:Cube ;
    dcterms:accrualPeriodicity frequency:ANNUAL ;
    dcterms:creator blw: ;
    schema:contributor blw: ;
    schema:creativeWorkStatus status:Draft ;
    schema:creator blw: ;
    schema:dateCreated "2026-03-10"^^xsd:date ;
    schema:datePublished "2026-03-10"^^xsd:date ;
    schema:description "Kulturen der Suisse-Bilanz und ihre Codes gemäss Wegleitung."@de ;
    schema:name "Suisse-Bilanz Kulturentabelle"@de ;
    schema:publisher blw: ;
    schema:version "1.18" ;
    schema:workExample <https://ld.admin.ch/application/visualize> ;
    dcat:contactPoint
        [
            a vcard:Organization ;
            vcard:fn "Bundesamt für Landwirtschaft"^^xsd:string ;
            vcard:hasEmail "info@blw.admin.ch"^^xsd:string
        ] ;
    dcat:theme theme:administration,
        theme:agriculture ;
    cube:observationConstraint naebi:ObservationConstraint ;
    cube:observationSet naebi:ObservationSet .

# ==============================================================================
# SHACL DATA MODEL
# ==============================================================================

naebi:ObservationConstraint a sh:NodeShape ;
    sh:closed true ;
    sh:property
        [
            sh:order 1 ;
            a cube:KeyDimension ;
            schema:name "Identifikator"@de,
                "Identifier"@en ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier ;
        ],
        [
            sh:order 2 ;
            schema:name "Kulturkategorie"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationCategory ;
        ],
        [
            sh:order 3 ;
            schema:name "Kultur"@de,
                "Crop"@en ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 4 ;
            schema:name "Ertrag Hauptprodukt"@de ;
            schema:description "Geerntet, mit einem bei der Ernte üblichen Wassergehalt."@de ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :yield ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:EA ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 5 ;
            schema:name "N"@de ;
            schema:description "Stickstoff, kg/ha"@de ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :nitrogen ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-HA ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 6 ;
            schema:name "P₂O₅"@de ;
            schema:description "Phosphor, kg/dt"@de ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :phosphorus ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 7 ;
            schema:name "K₂O"@de ;
            schema:description "Kalium, kg/dt"@de ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :potassium ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 8 ;
            schema:name "Mg"@de ;
            schema:description "Mangan, kg/dt"@de ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :manganese ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ] .

