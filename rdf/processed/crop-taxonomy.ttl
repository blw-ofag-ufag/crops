cultivationtype: a owl:Ontology ;
    dcterms:title "Kulturen-Taxonomie"@de,
        "Crop-Taxonomy"@en .

cultivationtype:shape a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:or ( [ sh:property [ sh:minCount 1 ;
                        sh:path rdfs:subClassOf ] ] [ sh:property [ sh:minCount 1 ;
                        sh:path owl:intersectionOf ] ] [ sh:property [ sh:minCount 1 ;
                        sh:path ( [ sh:inversePath rdf:first ] [ sh:zeroOrMorePath [ sh:inversePath rdf:rest ] ] [ sh:inversePath owl:unionOf ] ) ] ] ) ;
    sh:property [ sh:datatype rdf:langString ;
            sh:languageIn ( "de" "fr" "it" "en" ) ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path schema:name ;
            sh:uniqueLang true ],
        [ sh:datatype rdf:langString ;
            sh:languageIn ( "de" "fr" "it" "en" ) ;
            sh:nodeKind sh:Literal ;
            sh:path schema:alternateName ],
        [ sh:datatype rdf:langString ;
            sh:languageIn ( "de" "fr" "it" "en" ) ;
            sh:nodeKind sh:Literal ;
            sh:path schema:description ;
            sh:uniqueLang true ],
        [ sh:nodeKind sh:IRI ;
            sh:path rdfs:subClassOf ],
        [ sh:path owl:intersectionOf ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :botanicalPlant ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :intensity ],
        [ sh:node cultivationtype:shape ;
            sh:nodeKind sh:IRI ;
            sh:path owl:disjointWith ],
        [ sh:path owl:unionOf ] ;
    sh:targetClass owl:Class,
        owl:DeprecatedClass .

