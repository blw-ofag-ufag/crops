PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

INSERT {
  ?subjectClass rdfs:subClassOf ?intersectedClass .
}
WHERE {
  ?subjectClass owl:equivalentClass ?equivNode .  
  ?equivNode owl:intersectionOf ?listHead .  
  ?listHead rdf:rest*/rdf:first ?intersectedClass .
  FILTER(isIRI(?intersectedClass) || isBlank(?intersectedClass))
}